<h2 class="text-center"><%= t "dashboard.title" %></h2>

<div class="container mt-4">
  <div class="row">
    <div class="col-md-4">
      <div class="card mb-4">
        <div class="card-header bg-primary text-white">
          <i class="bi bi-person"></i> <%= t "dashboard.user.user_info" %>
        </div>
        <div class="card-body">
          <p><strong><%= t "dashboard.user.name" %>:</strong> <%= current_user.name %></p>
          <p><strong><%= t "dashboard.user.email" %>:</strong> <%= current_user.email %></p>
          <p><strong><%= t "dashboard.user.department" %>:</strong> <%= current_user.department&.name %></p>
          <p><strong><%= t "dashboard.user.manager" %>:</strong> <%= current_user.manager&.name %></p>
          <p><strong><%= t "dashboard.user.manager_email" %>:</strong> <%= current_user.manager&.email %></p>
        </div>
      </div>
    </div>

    <div class="col-md-8">
      <div class="card">
        <div class="card-header bg-success text-white">
          <i class="bi bi-calendar"></i> <%= t "dashboard.user.daily_report_progress" %>
        </div>
        <div class="card-body">
          <%= month_calendar(events: @daily_reports, attribute: :report_date) do |date, reports| %>
            <div class="day">
              <% report = reports.first %>
              <% if report.present? %>
                <% status_class = case report.status.to_sym
                                 when :pending then "bg-warning text-dark"
                                 when :read then "bg-info text-white"
                                 when :commented then "bg-success text-white"
                                 else "bg-light" end %>

                <%= link_to report.report_date.day,
                      user_daily_report_path(report),
                      class: "btn #{status_class} w-100 mb-2" %>
              <% else %>
                <span class="text-muted"><%= date.day %></span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
