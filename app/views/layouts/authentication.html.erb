<!DOCTYPE html>
<html>
<head>
  <title><%= content_for?(:title) ? yield(:title) : t("app_name") %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", media: "all" %>
  <%= stylesheet_link_tag "login", media: "all" %>
  <%= javascript_importmap_tags %>
</head>
<body>
  <div class="container">
    <% flash.each do |key, message| %>
      <div class="alert <%= {notice: "alert-success", alert: "alert-danger", warning: "alert-warning", info: "alert-info"}[key.to_sym] || "alert-info" %>">
        <%= message %>
      </div>
    <% end %>
    <%= yield %>
    <%= debug(params) if Rails.env.development? %>
  </div>
</body>
</html>
